# Server Configuration
PORT=5001

# Authentication
JWT_SECRET=your_jwt_secret_here

# Database
# Connect your MongoDB Atlas cluster and paste the URI below
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/urban_sanctuary?retryWrites=true&w=majority

# AI Chatbot
# Create a key in GroqCloud and paste it here.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
